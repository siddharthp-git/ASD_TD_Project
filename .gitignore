# Ignore everything at the workspace root by default
/*

# Allow tracking of the subdirectories
!/dv-sttgat-usm-cc400/
!/dv-sttgat-11-18-cc400-hyper/
!/dv-sttgat-ADOS-0-10-cc400-hyper/

# Allow the root .gitignore itself
!.gitignore

# Inside the target subdirectories, ignore environment, caches, and large binary artifacts
dv-sttgat-usm-cc400/venv/
dv-sttgat-usm-cc400/__pycache__/
dv-sttgat-usm-cc400/cc400_bold_cache/
dv-sttgat-usm-cc400/nilearn_cache/
dv-sttgat-usm-cc400/tmp/
dv-sttgat-usm-cc400/*.pt
dv-sttgat-usm-cc400/*.db

dv-sttgat-11-18-cc400-hyper/venv/
dv-sttgat-11-18-cc400-hyper/__pycache__/
dv-sttgat-11-18-cc400-hyper/cc400_bold_cache/
dv-sttgat-11-18-cc400-hyper/nilearn_cache/
dv-sttgat-11-18-cc400-hyper/tmp/
dv-sttgat-11-18-cc400-hyper/*.pt
dv-sttgat-11-18-cc400-hyper/*.db

dv-sttgat-ADOS-0-10-cc400-hyper/venv/
dv-sttgat-ADOS-0-10-cc400-hyper/__pycache__/
dv-sttgat-ADOS-0-10-cc400-hyper/cc400_bold_cache/
dv-sttgat-ADOS-0-10-cc400-hyper/nilearn_cache/
dv-sttgat-ADOS-0-10-cc400-hyper/tmp/
